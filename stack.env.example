# MSC Label Maker — Environment Variables
#
# Copy this file to 'stack.env' for local Docker usage,
# OR configure these directly in the Portainer UI (Stack > Environment variables).
#
# All variables are optional — the defaults shown below work out of the box.

# Port the API server is exposed on (default: 5002)
SERVER_PORT=5002

# Port the web client is exposed on (default: 80)
CLIENT_PORT=80
